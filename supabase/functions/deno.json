{
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.13",
    "@std/testing": "jsr:@std/testing@^1.0.14",
    "@supabase/supabase-js": "npm:@supabase/supabase-js@2.103.1",
    "zod": "npm:zod@3.25.76"
  },
  "compilerOptions": {
    "strict": true
  },
  "fmt": {
    "indentWidth": 2,
    "lineWidth": 100,
    "semiColons": true,
    "singleQuote": true
  },
  "lint": {
    "rules": {
      "exclude": [
        "require-await"
      ],
      "tags": [
        "recommended"
      ]
    }
  }
}
