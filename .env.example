# ──────────────────────────────────────
# Supabase — Core
# ──────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key                    # Client-safe
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key     # ⚠️ BACKEND ONLY — never in client bundles
DATABASE_URL=postgresql://...                       # Direct Postgres — migrations only

# ──────────────────────────────────────
# Storage buckets
# ──────────────────────────────────────
STORAGE_BUCKET_RECEIPTS=receipts
STORAGE_BUCKET_AVATARS=avatars

# ──────────────────────────────────────
# Feature flags
# ──────────────────────────────────────
FEATURE_FLAG_AI_CAPTURE=false                       # Off in local/staging by default
FEATURE_FLAG_VOICE_INPUT=false                      # Off in local/staging by default

# ──────────────────────────────────────
# Observability
# ──────────────────────────────────────
SENTRY_DSN=https://...                              # Staging + beta + prod only
