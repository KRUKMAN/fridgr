# ============================================================
# Fridgr - Environment Variables
# ============================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env or .env.local to version control.
#
# Legend:
#   [CLIENT-SAFE]   - can appear in Expo/EAS client builds
#   [BACKEND-ONLY]  - server-side only, NEVER in client bundles
#   [PER-ENV]       - value differs per environment (dev/staging/beta/prod)
# ============================================================

# -- Supabase - Core -----------------------------------------
# Dev project: cgwvkilrojueftbbrfvq
# Staging project: roxosxqmzossvzvcmlat

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres:...@db....supabase.co:5432/postgres

# -- Expo / Client-safe Supabase -----------------------------
# These are the only Supabase vars that may appear in client builds.
# EAS injects them per build profile (development / staging / production).

EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# -- App Environment -----------------------------------------
# This helps the app know which Expo/EAS environment it is running against.

EXPO_PUBLIC_APP_ENV=development

# -- Storage Buckets -----------------------------------------
# Bucket names are the same across all environments.

# Staging Environment
STAGING_SUPABASE_URL=https://your-staging-project-id.supabase.co
STAGING_SUPABASE_ANON_KEY=your-staging-anon-key-here
STAGING_SUPABASE_SERVICE_ROLE_KEY=your-staging-service-role-key-here  # BACKEND ONLY - never in client bundles

# Storage buckets
STORAGE_BUCKET_RECEIPTS=receipts
STORAGE_BUCKET_AVATARS=avatars

# -- Feature Flags -------------------------------------------
# Default to false in local + staging. Enable in beta/prod when ready.

FEATURE_FLAG_AI_CAPTURE=false
FEATURE_FLAG_VOICE_INPUT=false
